# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Admin detection - the Google account with this email gets is_admin=True
ADMIN_EMAIL=admin@example.com

# JWT signing secret - use a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# Database (optional - defaults to sqlite:///./app.db)
# DATABASE_URL=sqlite:///./app.db

# Server (optional - defaults shown)
# HOST=127.0.0.1
# PORT=5000

# Gmail SMTP settings for sending event notifications
# To generate an App Password:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Step Verification if not already enabled
# 3. Go to "App passwords" (search for it)
# 4. Select "Mail" and your device
# 5. Copy the 16-character password and paste it below
SENDER_EMAIL=your-email@gmail.com
APP_PASSWORD=your-app-password
